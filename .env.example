# Multi-Agent SalesOps Arena — Environment Variables
# ─────────────────────────────────────────────────────
# Copy this to .env and fill in your values.

# ── HuggingFace Credentials ───────────────────────────────────────────────
# Get a free token at: https://huggingface.co/settings/tokens
# NOTE: The HF Inference Router (2025) requires a paid plan or billing credits.
# Free-tier tokens will gracefully fall back to rule-based agent logic.
HF_TOKEN=hf_your_token_here

# ── Model Selection ───────────────────────────────────────────────────────
# Any model available on HF Inference Router.
# Recommended options:
#   meta-llama/Llama-3.1-8B-Instruct      (fast, good quality)
#   meta-llama/Llama-3.2-3B-Instruct      (faster, lighter)
#   mistralai/Mistral-7B-Instruct-v0.3    (strong reasoning)
#   Qwen/Qwen2.5-72B-Instruct             (highest quality)
HF_MODEL=meta-llama/Llama-3.1-8B-Instruct

# ── Router Endpoint ───────────────────────────────────────────────────────
# HF Inference Router — OpenAI-compatible chat completions endpoint (2025)
# Do NOT use the deprecated api-inference.huggingface.co/models endpoint.
HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions

# ── Feature Flag ──────────────────────────────────────────────────────────
# Set to "false" to force rule-based fallback (useful for offline demos)
USE_HF=true
